{
    "_comment": "Odin language definition for doc-gen. Add keywords/types/procs here as the language evolves — gen.py reads this to build the JS highlighter. Theme colours live in the theme file.",

    "keywords": [
        "package", "import",
        "proc", "struct", "enum", "union", "bit_set", "map", "dynamic", "matrix",
        "return", "defer",
        "if", "else", "when", "for", "switch", "case",
        "break", "continue", "fallthrough",
        "using", "context", "foreign", "distinct",
        "where", "do",
        "in", "not_in", "or_else", "or_return",
        "auto_cast", "cast", "transmute"
    ],

    "builtin_types": [
        "bool", "b8", "b16", "b32", "b64",
        "byte", "rune", "string", "cstring", "rawptr",
        "any", "typeid",
        "int", "uint", "uintptr",
        "i8",  "i16",  "i32",  "i64",  "i128",
        "u8",  "u16",  "u32",  "u64",  "u128",
        "f16", "f32",  "f64",
        "f16le", "f16be", "f32le", "f32be", "f64le", "f64be",
        "complex32", "complex64", "complex128",
        "quaternion64", "quaternion128", "quaternion256"
    ],

    "builtin_procs": [
        "len", "cap",
        "size_of", "align_of", "offset_of",
        "type_of", "type_info_of", "typeid_of",
        "make", "new", "new_clone",
        "free", "free_all", "delete",
        "append", "append_elem", "append_elems", "append_nothing", "assign_at",
        "clear", "reserve", "resize", "shrink", "copy",
        "unordered_remove", "ordered_remove", "pop", "push",
        "swizzle", "complex", "real", "imag", "conj", "expand_to_tuple",
        "min", "max", "abs", "clamp",
        "assert", "assertf", "panic", "panicf", "unreachable",
        "print", "println", "printf", "fprintf", "sprintf",
        "eprintf", "eprintln", "eprintfln"
    ],

    "literals": ["true", "false", "nil"],

    "_comment_token_classes": "Flat map: semantic role -> CSS class used by the highlighter and style.template.css.",
    "token_classes": {
        "comment":   "cm",
        "string":    "str",
        "fn_name":   "fn",
        "type_name": "ty",
        "keyword":   "kw",
        "builtin":   "bi",
        "literal":   "bl",
        "number":    "nm",
        "directive": "dr",
        "attribute": "at",
        "decl_sep":  "dc",
        "assign":    "as",
        "pointer":   "pt",
        "arrow":     "ar",
        "operator":  "op"
    }
}
